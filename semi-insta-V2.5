local desyncEnabled = false

local function setFFlag(name, value)
    pcall(function() setfflag(name, tostring(value)) end)
end

local function toggleDesync(state)
    setFFlag("NextGenReplicatorEnabledWrite4", state)
    desyncEnabled = state
    
    if state then
        status.Text = "Desync: ON 🔥"
    else
        status.Text = "Desync: OFF"
    end
end

