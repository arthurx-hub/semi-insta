local function findFlyingTool()
    local backpack = LP:FindFirstChild("Backpack")
    local char = LP.Character

    for _, name in ipairs(flyingPriority) do
        local tool =
            (backpack and backpack:FindFirstChild(name))
            or (char and char:FindFirstChild(name))

        if tool then
            return tool
        end
    end

    return nil
end

