local function getHumanoid()
    local char = LP.Character
    if not char then return nil end
    return char:FindFirstChildOfClass("Humanoid")
end

local function equipToolByName(name)
    local char = LP.Character
    if not char then return nil end
    local hum = getHumanoid()
    if not hum then return nil end

    local tool = char:FindFirstChild(name)
    if not tool then
        local backpack = LP:FindFirstChild("Backpack")
        if backpack then
            tool = backpack:FindFirstChild(name)
        end
    end

    if tool and hum then
        hum:EquipTool(tool)
        return tool
    end
    return nil
end

local function unequipAllTools()
    local hum = getHumanoid()
    if hum then
        pcall(function()
            hum:UnequipTools()
        end)
    end
end

local function useGiantPotion()
    unequipAllTools()

    local potion = equipToolByName("Giant Potion")
    if not potion then
        status.Text = "No Giant Potion ❌"
        return false
    end

    if potion:IsA("Tool") then
        pcall(function()
            potion:Activate()
        end)
    end

    unequipAllTools()
    return true
end

local function equipFlyingItem()
    local hum = getHumanoid()
    if not hum then return false end

    local tool = findFlyingTool()
    if not tool then
        status.Text = "No flying item ❌"
        return false
    end

    hum:EquipTool(tool)
    return true
end

