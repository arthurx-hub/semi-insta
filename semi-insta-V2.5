local function selectBase(choice)
    getgenv().BaseChoice = choice

    -- Animate all billboards at once
    local billboardTweens = {}
    for _, v in ipairs(baseBillboards) do
        local tween = TweenService:Create(v.gui, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size=UDim2.new(0,0,0,0)})
        tween:Play()
        table.insert(billboardTweens, tween)
    end

    -- Animate frame at the same time
    local fadeTween = TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size=UDim2.new(0,0,0,0), BackgroundTransparency = 1})
    fadeTween:Play()

    -- Wait for all tweens to finish
    for _, tween in ipairs(billboardTweens) do
        tween.Completed:Wait()
    end
    fadeTween.Completed:Wait()

    -- Destroy billboards
    for _, v in ipairs(baseBillboards) do
        v.part:Destroy()
    end
    baseBillboards = {}

    -- Destroy UI
    intro:Destroy()
end

